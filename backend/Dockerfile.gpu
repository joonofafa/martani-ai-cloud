FROM rocm/pytorch:latest

WORKDIR /app

ENV HSA_OVERRIDE_GFX_VERSION=11.0.0

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    libpq-dev \
    ffmpeg \
    libmediainfo-dev \
    tesseract-ocr \
    tesseract-ocr-kor \
    poppler-utils \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first for better caching
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY requirements-gpu.txt .
# Install whisper with --no-deps to prevent CUDA torch from overwriting ROCm torch
# setuptools needed for whisper's setup.py build, --no-build-isolation reuses it
# Then install whisper's actual runtime dependencies separately
RUN pip install --no-cache-dir setuptools \
    && pip install --no-cache-dir --no-deps --no-build-isolation openai-whisper==20231117 \
    && pip install --no-cache-dir more-itertools tiktoken numba

# Copy application code
COPY . .

# Default: run celery gpu worker
CMD ["celery", "-A", "app.core.celery_app:celery_app", "worker", "--loglevel=info", "--concurrency=1", "-Q", "gpu"]
