# ============================================
# Martani - Environment Variables
# ============================================

# Application
APP_NAME=Martani
DEBUG=true
SECRET_KEY=CHANGE_ME_MIN_32_CHARS

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql://martani:CHANGE_ME_DB_PASSWORD@localhost:5432/martani

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (S3 Compatible Storage)
MINIO_ENDPOINT=localhost:9000
MINIO_PUBLIC_ENDPOINT=https://your-domain.example
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
MINIO_BUCKET=martani-storage
MINIO_SECURE=false

# LLM Provider (ollama or openrouter)
LLM_PROVIDER=openrouter

# Ollama (Local LLM) - Use if LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OpenRouter (Cloud LLM) - Use if LLM_PROVIDER=openrouter
# Get your API key from https://openrouter.ai/
OPENROUTER_API_KEY=CHANGE_ME_OPENROUTER_API_KEY
OPENROUTER_MODEL=openai/gpt-4o-mini
